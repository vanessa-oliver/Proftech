<div class="create-quest-container">
    <div class="create-quest-wrapper">
        <div class="form-card">
            <h2 class="section-title mb-4">
                <i class="bi bi-plus-circle"></i> Criar Nova Questão
            </h2>

            {{#if erros}}
                {{#each erros}}
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-circle"></i> {{texto}}
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                {{/each}}
            {{/if}}

            <form action="/quest/addquest" method="post" id="formQuestao">
                <div class="form-section mb-4">
                    <h5 class="form-section-title">📝 Informações da Questão</h5>
                    
                    <div class="form-group mb-3">
                        <label for="enunciado" class="form-label">
                            <i class="bi bi-chat-square-text"></i> Enunciado *
                        </label>
                        <textarea class="form-control form-control-lg" id="enunciado" name="enunciado" 
                            placeholder="Digite o enunciado da questão..." rows="4" required></textarea>
                    </div>

                    <div class="form-group mb-3">
                        <label for="resposta" class="form-label">
                            <i class="bi bi-check-circle"></i> Resposta *
                        </label>
                        <textarea class="form-control form-control-lg" id="resposta" name="resposta" 
                            placeholder="Digite a resposta esperada..." rows="3" required></textarea>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label for="cod_usuario" class="form-label">
                                    <i class="bi bi-person"></i> Professor (Usuário) *
                                </label>
                                <div class="d-flex gap-2">
                                    <select class="form-select form-select-lg" id="cod_usuario" name="cod_usuario" required>
                                        <option value="">Selecione um professor...</option>
                                        {{#if usuarios}}
                                            {{#each usuarios}}
                                                <option value="{{cod_usuario}}">{{nome}}</option>
                                            {{/each}}
                                        {{/if}}
                                    </select>
                                    <a href="/user/cadastro?redirect=/quest/createquest" class="btn btn-outline-primary" title="Criar novo professor">
                                        <i class="bi bi-plus-lg"></i>
                                    </a>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label for="cod_assunto" class="form-label">
                                    <i class="bi bi-book"></i> Assunto *
                                </label>
                                <div class="d-flex gap-2">
                                    <select class="form-select form-select-lg" id="cod_assunto" name="cod_assunto" required>
                                        <option value="">Selecione um assunto...</option>
                                        {{#if assuntos}}
                                            {{#each assuntos}}
                                                <option value="{{cod_assunto}}">{{nome_assunto}}</option>
                                            {{/each}}
                                        {{/if}}
                                    </select>
                                    <a href="/subject/createassunto?redirect=/quest/createquest" class="btn btn-outline-primary" title="Criar novo assunto">
                                        <i class="bi bi-plus-lg"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-success btn-lg">
                        <i class="bi bi-check-circle"></i> Criar Questão
                    </button>
                    <a href="/quest/listquest" class="btn btn-secondary btn-lg">
                        <i class="bi bi-x-circle"></i> Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('formQuestao');
    
    // Validar que todos os campos obrigatórios são preenchidos
    if (form) {
        form.addEventListener('submit', function(e) {
            const enunciado = document.getElementById('enunciado').value.trim();
            const resposta = document.getElementById('resposta').value.trim();
            const codUsuario = document.getElementById('cod_usuario').value.trim();
            const codAssunto = document.getElementById('cod_assunto').value.trim();

            if (!enunciado || !resposta || !codUsuario || !codAssunto) {
                e.preventDefault();
                alert('Por favor, preencha todos os campos obrigatórios!');
                return false;
            }
        });
    }
});
</script>

