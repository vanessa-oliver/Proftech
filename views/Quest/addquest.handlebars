    color: #667eea;
    font-weight: 700;
    border-bottom: 3px solid #667eea;
    padding-bottom: 15px;
    margin-bottom: 25px;
    font-size: 1.5rem;
}

.form-section-title {
    color: #333;
    font-weight: 600;
    margin-bottom: 20px;
    font-size: 1.1rem;
}

.form-label {
    font-weight: 600;
    color: #333;
    margin-bottom: 8px;
}

.form-control,
.form-control-lg {
    border: 2px solid #e9ecef;
    border-radius: 8px;
    padding: 0.75rem 1rem;
    font-size: 1rem;
    transition: all 0.3s ease;
}

