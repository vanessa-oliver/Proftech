@media (max-width: 768px) {
    .create-quest-container {
        padding: 1rem 0.5rem;
    }

    .form-card {
        padding: 20px;
    }

    .section-title {
        font-size: 1.2rem;
    }

    .form-actions {
        grid-template-columns: 1fr;
    }
}
</style>