<div class="container-fluid mt-5 mb-5" style="padding: 0 40px;">
  <div class="row mb-4">
    <div class="col-12 text-center">
      <h1 class="mb-4">❓ Questões</h1>
      <div class="btn-group" role="group">
        <a href="/quest/createquest" class="btn btn-primary btn-lg">
          <i class="bi bi-plus-circle"></i> Criar Questão Manual
        </a>
        <a href="/IA/chat" class="btn btn-success btn-lg">
          <i class="bi bi-robot"></i> Criar com IA
        </a>
      </div>
    </div>
  </div>

  {{#if questoes.length}}
    <div class="row">
      {{#each questoes}}
        <div class="col-md-6 col-lg-4 mb-4">
          <div class="card h-100 shadow-sm quest-card">
            <div class="card-body">
              <h5 class="card-title quest-number">Questão #{{cod_questao}}</h5>
              <p class="card-text quest-enunciado">{{enunciado}}</p>
              
              <div class="d-grid gap-2 mt-3">
                <a href="/quest/readquest/{{cod_questao}}" class="btn btn-info btn-sm">
                  <i class="bi bi-eye"></i> Visualizar
                </a>
                <a href="/quest/updatequest/{{cod_questao}}" class="btn btn-warning btn-sm">
                  <i class="bi bi-pencil"></i> Editar
                </a>
                <form action="/quest/delquest/{{cod_questao}}" method="GET" style="margin: 0;">
                  <button type="submit" class="btn btn-danger btn-sm w-100" onclick="return confirm('Tem certeza que deseja deletar?')">
                    <i class="bi bi-trash"></i> Deletar
                  </button>
                </form>
              </div>
            </div>
          </div>
        </div>
      {{/each}}
    </div>
  {{else}}
    <div class="row">
      <div class="col-12">
        <div class="alert alert-info alert-lg" role="alert">
          <i class="bi bi-info-circle"></i> <strong>Nenhuma questão criada ainda!</strong>
          <a href="/quest/createquest" class="alert-link">Crie uma questão</a> ou 
          <a href="/IA/chat" class="alert-link">use IA</a>
        </div>
      </div>
    </div>
  {{/if}}
</div>

<style>
  .btn-group {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .quest-card {
    transition: all 0.3s ease;
    border: 2px solid #f0f0f0;
    cursor: pointer;
  }

  .quest-card:hover {
    transform: translateY(-8px);
    border-color: #667eea;
    box-shadow: 0 12px 24px rgba(102, 126, 234, 0.2) !important;
  }

  .quest-number {
    background-color: #667eea;
    color: white;
    padding: 8px 12px;
    border-radius: 6px;
    display: inline-block;
    font-size: 0.9rem;
    margin-bottom: 15px;
  }

  .quest-enunciado {
    color: #333;
    line-height: 1.6;
    font-size: 0.95rem;
    min-height: 60px;
  }

  .btn-sm {
    font-size: 0.9rem;
    padding: 0.5rem 1rem;
  }

  .alert-lg {
    padding: 2rem;
    font-size: 1.1rem;
  }

  h1 {
    color: #333;
    font-weight: 600;
  }

  @media (max-width: 768px) {
    .btn-group {
      flex-direction: column;
    }

    .btn-group .btn {
      width: 100%;
    }

    .col-md-6 {
      flex: 0 0 100%;
    }
  }
</style>
