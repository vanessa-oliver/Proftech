<div class="ia-chat-container">
    <div class="ia-chat-wrapper">
        <div class="chat-card">
            <div class="chat-header">
                <h1 class="chat-title">
                    <i class="bi bi-lightning-charge"></i> Gerar Questões com IA
                </h1>
                <p class="chat-subtitle">Descreva o tema e a IA criará uma questão para você</p>
            </div>

            <div class="chat-messages" id="messages">
                <div class="welcome-message">
                    <i class="bi bi-chat-dots"></i>
                    <p>Olá! Sou uma IA criada para ajudar você a gerar questões.</p>
                    <p>Digite um tema ou comando e vou criar uma questão automaticamente.</p>
                </div>
            </div>

            <div class="chat-input-section">
                <div class="input-group">
                    <input 
                        type="text" 
                        id="user-input" 
                        class="form-control chat-input" 
                        placeholder="Ex: Crie uma questão sobre a Revolução Francesa..."
                        autocomplete="off">
                    <button type="button" id="send-button" class="btn btn-primary btn-send">
                        <i class="bi bi-send-fill"></i> Enviar
                    </button>
                </div>
            </div>

            <div class="chat-actions mt-4">
                <button id="save-button" class="btn btn-success btn-lg w-100 mb-2">
                    <i class="bi bi-download"></i> Salvar Questão Gerada
                </button>
                <a href="/quest/listquest" class="btn btn-secondary btn-lg w-100">
                    <i class="bi bi-list"></i> Ver Minhas Questões
                </a>
            </div>
        </div>
    </div>
</div>

<style>
